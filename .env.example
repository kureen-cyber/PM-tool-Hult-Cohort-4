# Copy to .env.local and fill with your Firebase web app config
# (Firebase Console → Project settings → Your apps → SDK setup)

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated emails that receive staff roles on registration.
# Professors get Back office access; admins get the same plus elevated role.
VITE_STAFF_EMAILS=professor@hult.edu
VITE_ADMIN_EMAILS=admin@hult.edu

# Optional: restrict register/login to rostered participant emails only.
# Leave empty to allow any real Firebase-registered participant account.
# VITE_COHORT_EMAILS=ada@hult.edu,liam@hult.edu

# Optional: power the floating AI assistant with OpenAI (otherwise local replies).
# VITE_OPENAI_API_KEY=
# VITE_OPENAI_MODEL=gpt-4o-mini

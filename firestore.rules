rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function ownRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff() {
      return signedIn() && userDocExists() && ownRole() in ['professor', 'admin'];
    }

    function isAdmin() {
      return signedIn() && userDocExists() && ownRole() == 'admin';
    }

    match /users/{userId} {
      // Signed-in participants can read the cohort directory (chat / assignees).
      allow read: if signedIn();
      allow create: if isSelf(userId)
        && request.resource.data.keys().hasAll(['email', 'role', 'firstName', 'lastName'])
        && request.resource.data.role in ['student', 'professor', 'admin'];
      allow update: if isAdmin()
        || (isSelf(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email);
      allow delete: if isAdmin();
    }

    match /registrations/{regId} {
      allow read: if isStaff() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /pmProjects/{projectId} {
      allow read, write: if signedIn();
    }

    match /pmTasks/{taskId} {
      allow read, write: if signedIn();
    }
  }
}
